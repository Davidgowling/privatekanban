<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kanban</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-left">
      <div class="menu-trigger" id="menuTrigger">
        <div class="hamburger-icon">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <span class="menu-caret">▾</span>
      </div>

      <div class="dropdown hidden" id="mainMenu">
        <div class="menu-section">
          <div class="menu-user">
            <div class="menu-user-name"><%= currentUser %></div>
            <div class="menu-user-sub">Signed in</div>
          </div>
        </div>
        <div class="menu-section">
          <div class="menu-item" id="menuAddBoard">
            <span class="menu-icon">+</span>
            Add board
          </div>
          <div class="menu-add-board-form hidden" id="menuAddBoardForm">
            <input type="text" id="newBoardName" class="menu-input" placeholder="Board name…" />
            <div class="menu-form-btns">
              <button type="button" class="flat-btn" id="menuAddBoardSubmit">Add</button>
              <button type="button" class="flat-btn muted" id="menuAddBoardCancel">Cancel</button>
            </div>
          </div>
        </div>
        <div class="menu-section">
          <div class="menu-item" id="menuSettings">
            <span class="menu-icon">&#9881;</span>
            Settings
          </div>
          <form method="POST" action="/logout">
            <button type="submit" class="menu-item menu-item-btn">
              <span class="menu-icon">&#8594;</span>
              Logout
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="topbar-right">
      <span class="app-title">Kanban</span>
      <svg class="app-logo-svg" width="36" height="36" viewBox="0 0 48 48">
        <rect width="48" height="48" rx="11" fill="#1e1b4b"/>
        <rect x="10" y="22" width="28" height="13" rx="3" fill="#a855f7" opacity="0.5"/>
        <rect x="10" y="15" width="28" height="13" rx="3" fill="#6366f1" opacity="0.8"/>
        <rect x="10" y="8"  width="28" height="13" rx="3" fill="white"/>
        <rect x="14" y="11" width="8" height="2" rx="1" fill="#6366f1" opacity="0.5"/>
        <rect x="14" y="18" width="12" height="2" rx="1" fill="#a5b4fc" opacity="0.5"/>
      </svg>
    </div>
  </header>

  <main class="boards-wrap">
    <% boards.forEach(board => { %>
      <section class="board-section" data-board-id="<%= board.id %>">
        <div class="board-header">
          <div class="board-title-row">
            <h2 class="board-title"><%= board.name %></h2>
            <i class="ic rename-board" title="Rename board"
              data-board-id="<%= board.id %>" data-board-name="<%= board.name %>">&#9998;</i>
            <i class="ic del delete-board" title="Delete board"
              data-board-id="<%= board.id %>">&#10005;</i>
          </div>
          <form class="board-col-form" data-board-id="<%= board.id %>">
            <input type="text" name="name" class="flat-input" placeholder="New column" required />
            <button type="submit" class="flat-btn">Add column</button>
          </form>
        </div>

        <div class="columns-grid" style="grid-template-columns: repeat(<%= Math.max(board.columns.length, 1) %>, minmax(200px, 1fr));">
          <% board.columns.forEach(column => { %>
            <div class="column" data-column-id="<%= column.id %>">
              <div class="col-header">
                <span class="col-name"><%= column.name %></span>
                <div class="col-controls">
                  <i class="ic rename-column" title="Rename column"
                    data-column-id="<%= column.id %>" data-column-name="<%= column.name %>">&#9998;</i>
                  <i class="ic del delete-column" title="Delete column"
                    data-column-id="<%= column.id %>">&#10005;</i>
                  <i class="ic plus add-card-toggle" title="Add card">&#43;</i>
                  <span class="count"><%= column.cards.length %></span>
                </div>
              </div>

              <form class="add-card-form" data-column-id="<%= column.id %>" style="display:none;">
                <input type="text" name="title" placeholder="Card title…" required />
                <textarea name="description" placeholder="Notes (optional)"></textarea>
                <div class="card-form-row">
                  <input type="date" name="due_date" />
                  <select name="color">
                    <option value="">No label</option>
                    <option value="#6366f1">Indigo</option>
                    <option value="#a855f7">Violet</option>
                    <option value="#ef4444">Red</option>
                    <option value="#f97316">Orange</option>
                    <option value="#eab308">Yellow</option>
                    <option value="#22c55e">Green</option>
                    <option value="#3b82f6">Blue</option>
                  </select>
                </div>
                <div class="form-btns">
                  <button type="submit" class="flat-btn">Add card</button>
                  <button type="button" class="flat-btn muted cancel-add-card">Cancel</button>
                </div>
              </form>

              <div class="card-list" data-column-id="<%= column.id %>">
                <% column.cards.forEach(card => { %>
                  <%
                    let dueBadgeHtml = '';
                    if (card.due_date) {
                      const d = new Date(card.due_date + 'T00:00:00');
                      const today = new Date(); today.setHours(0,0,0,0);
                      const diff = Math.round((d - today) / (1000*60*60*24));
                      const label = d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
                      let cls = 'due-badge';
                      if (diff < 0) cls += ' due-overdue';
                      else if (diff <= 2) cls += ' due-soon';
                      dueBadgeHtml = `<span class="${cls}">${label}</span>`;
                    }
                    const borderStyle = card.color ? `border-left-color:${card.color};` : '';
                  %>
                  <article
                    class="card"
                    draggable="true"
                    data-card-id="<%= card.id %>"
                    data-column-id="<%= column.id %>"
                    <% if (card.due_date) { %>data-due-date="<%= card.due_date %>"<% } %>
                    style="<%= borderStyle %>"
                  >
                    <div class="card-top">
                      <strong class="card-title"><%= card.title %></strong>
                      <div class="card-icons">
                        <i class="ic edit-card" title="Edit">&#9998;</i>
                        <i class="ic del delete-card" title="Delete">&#10005;</i>
                      </div>
                    </div>
                    <% if (card.description) { %>
                      <p class="card-desc"><%= card.description %></p>
                    <% } %>
                    <%- dueBadgeHtml %>
                  </article>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% }) %>

    <% if (boards.length === 0) { %>
      <div class="empty-state">
        <p>No boards yet.</p>
        <p class="app-sub">Open the menu and click Add board to get started.</p>
      </div>
    <% } %>
  </main>

  <!-- Edit card modal -->
  <div id="editModal" class="modal hidden">
    <div class="modal-card">
      <h3>Edit card</h3>
      <form id="editCardForm" class="stack">
        <input type="hidden" id="editCardId" />
        <label>
          <span>Title</span>
          <input type="text" id="editTitle" required />
        </label>
        <label>
          <span>Description</span>
          <textarea id="editDescription"></textarea>
        </label>
        <div class="modal-row">
          <label>
            <span>Due date</span>
            <input type="date" id="editDueDate" />
          </label>
          <label>
            <span>Label colour</span>
            <select id="editColor">
              <option value="">No label</option>
              <option value="#6366f1">Indigo</option>
              <option value="#a855f7">Violet</option>
              <option value="#ef4444">Red</option>
              <option value="#f97316">Orange</option>
              <option value="#eab308">Yellow</option>
              <option value="#22c55e">Green</option>
              <option value="#3b82f6">Blue</option>
            </select>
          </label>
        </div>
        <div class="modal-actions">
          <button type="submit" class="flat-btn">Save</button>
          <button type="button" id="closeModal" class="flat-btn muted">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Settings modal -->
  <div id="settingsModal" class="modal hidden">
    <div class="modal-card">
      <h3>Settings</h3>

      <div class="settings-section">
        <div class="settings-label">Account</div>
        <p class="settings-desc">Signed in as <strong><%= currentUser %></strong></p>
      </div>

      <div class="settings-section settings-danger">
        <div class="settings-label danger">Danger zone</div>
        <p class="settings-desc">Permanently delete your account and all your boards, columns and cards. This cannot be undone.</p>
        <button type="button" id="deleteAccountBtn" class="flat-btn danger">Delete my account</button>
      </div>

      <div class="modal-actions" style="margin-top:20px;">
        <button type="button" id="closeSettings" class="flat-btn muted">Close</button>
      </div>
    </div>
  </div>

  <script src="/app.js"></script>
</body>
</html>
