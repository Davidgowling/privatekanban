<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kanban</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-left">
      <div class="app-logo">
        <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
          <rect x="1" y="1" width="4" height="10" rx="1"/>
          <rect x="6" y="1" width="4" height="7" rx="1"/>
          <rect x="11" y="1" width="4" height="13" rx="1"/>
        </svg>
      </div>
      <div>
        <h1>Kanban</h1>
        <p class="muted small-text">Signed in as <strong><%= currentUser %></strong></p>
      </div>
    </div>

    <div class="topbar-actions">
      <form id="addBoardForm" class="inline-form">
        <input type="text" id="newBoardName" placeholder="New board name" required />
        <button type="submit" class="tiny-button">Add board</button>
      </form>

      <form method="POST" action="/logout">
        <button type="submit" class="secondary-button tiny-button">Logout</button>
      </form>
    </div>
  </header>

  <main class="boards-wrap">
    <% boards.forEach(board => { %>
      <section class="board-section" data-board-id="<%= board.id %>">
        <div class="board-header board-header-flex">
          <div class="board-title-wrap">
            <h2 class="board-title"><%= board.name %></h2>
            <button
              type="button"
              class="tiny-button secondary-button rename-board"
              data-board-id="<%= board.id %>"
              data-board-name="<%= board.name %>"
            >Rename</button>
            <button
              type="button"
              class="tiny-button danger delete-board"
              data-board-id="<%= board.id %>"
            >Delete</button>
          </div>

          <form class="add-column-form inline-form" data-board-id="<%= board.id %>">
            <input type="text" name="name" placeholder="New column" required />
            <button type="submit" class="tiny-button">Add column</button>
          </form>
        </div>

        <div class="columns-grid dynamic-grid" style="grid-template-columns: repeat(<%= Math.max(board.columns.length, 1) %>, minmax(220px, 1fr));">
          <% board.columns.forEach(column => { %>
            <div class="column" data-column-id="<%= column.id %>">
              <div class="column-header">
                <div class="column-title-wrap">
                  <h3><%= column.name %></h3>
                  <button
                    type="button"
                    class="tiny-button secondary-button rename-column"
                    data-column-id="<%= column.id %>"
                    data-column-name="<%= column.name %>"
                  >Edit</button>
                  <button
                    type="button"
                    class="tiny-button danger delete-column"
                    data-column-id="<%= column.id %>"
                  >X</button>
                </div>
                <span class="count"><%= column.cards.length %></span>
              </div>

              <form class="add-card-form" data-column-id="<%= column.id %>">
                <input type="text" name="title" placeholder="Add a card…" required />
                <textarea name="description" placeholder="Optional notes"></textarea>
                <div class="card-form-row">
                  <input type="date" name="due_date" title="Due date" />
                  <select name="color" title="Label colour">
                    <option value="">No label</option>
                    <option value="#ef4444">Red</option>
                    <option value="#f97316">Orange</option>
                    <option value="#eab308">Yellow</option>
                    <option value="#22c55e">Green</option>
                    <option value="#3b82f6">Blue</option>
                    <option value="#a855f7">Purple</option>
                  </select>
                  <button type="submit" class="tiny-button">Add</button>
                </div>
              </form>

              <div class="card-list" data-column-id="<%= column.id %>">
                <% column.cards.forEach(card => { %>
                  <%
                    let dueBadgeHtml = '';
                    if (card.due_date) {
                      const d = new Date(card.due_date + 'T00:00:00');
                      const today = new Date(); today.setHours(0,0,0,0);
                      const diff = Math.round((d - today) / (1000*60*60*24));
                      const label = d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
                      let cls = 'due-badge';
                      if (diff < 0) cls += ' due-overdue';
                      else if (diff <= 2) cls += ' due-soon';
                      dueBadgeHtml = `<span class="${cls}">${label}</span>`;
                    }
                    const borderStyle = card.color ? `border-left: 3px solid ${card.color};` : '';
                  %>
                  <article
                    class="card"
                    draggable="true"
                    data-card-id="<%= card.id %>"
                    data-column-id="<%= column.id %>"
                    <% if (card.due_date) { %>data-due-date="<%= card.due_date %>"<% } %>
                    style="<%= borderStyle %>"
                  >
                    <strong class="card-title"><%= card.title %></strong>

                    <% if (card.description) { %>
                      <p class="card-desc"><%= card.description %></p>
                    <% } %>

                    <%- dueBadgeHtml %>

                    <div class="card-actions">
                      <button type="button" class="tiny-button secondary-button edit-card">Edit</button>
                      <button type="button" class="tiny-button danger delete-card">Delete</button>
                    </div>
                  </article>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% }) %>

    <% if (boards.length === 0) { %>
      <div style="text-align:center; padding: 60px 20px; color: #9ca3af;">
        <p style="font-size:16px; margin-bottom:8px;">No boards yet.</p>
        <p style="font-size:13px;">Type a board name above and click "Add board" to get started.</p>
      </div>
    <% } %>
  </main>

  <!-- Edit card modal -->
  <div id="editModal" class="modal hidden">
    <div class="modal-card">
      <h3>Edit card</h3>
      <form id="editCardForm" class="stack">
        <input type="hidden" id="editCardId" />
        <label>
          <span>Title</span>
          <input type="text" id="editTitle" required />
        </label>
        <label>
          <span>Description</span>
          <textarea id="editDescription"></textarea>
        </label>
        <div class="modal-row">
          <label>
            <span>Due date</span>
            <input type="date" id="editDueDate" />
          </label>
          <label>
            <span>Label colour</span>
            <select id="editColor" style="width:100%; padding:7px 10px; border:1px solid #d1d5db; border-radius:8px; font-size:13px;">
              <option value="">No label</option>
              <option value="#ef4444">Red</option>
              <option value="#f97316">Orange</option>
              <option value="#eab308">Yellow</option>
              <option value="#22c55e">Green</option>
              <option value="#3b82f6">Blue</option>
              <option value="#a855f7">Purple</option>
            </select>
          </label>
        </div>
        <div class="modal-actions">
          <button type="submit" class="tiny-button">Save</button>
          <button type="button" id="closeModal" class="secondary-button tiny-button">Cancel</button>
        </div>
      </form>

      <div class="danger-zone">
        <h3>Danger zone</h3>
        <p>Permanently delete your account and all your data. This cannot be undone.</p>
        <button type="button" id="deleteAccountBtn" class="tiny-button danger">Delete my account</button>
      </div>
    </div>
  </div>

  <script src="/app.js"></script>
</body>
</html>
