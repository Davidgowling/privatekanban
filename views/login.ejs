<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kanban — Sign in</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-page">
  <div class="auth-shell">

    <div class="auth-brand">
      <svg width="38" height="38" viewBox="0 0 48 48">
        <rect width="48" height="48" rx="11" fill="#1e1b4b"/>
        <rect x="10" y="22" width="28" height="13" rx="3" fill="#a855f7" opacity="0.5"/>
        <rect x="10" y="15" width="28" height="13" rx="3" fill="#6366f1" opacity="0.8"/>
        <rect x="10" y="8"  width="28" height="13" rx="3" fill="white"/>
        <rect x="14" y="11" width="8" height="2" rx="1" fill="#6366f1" opacity="0.5"/>
        <rect x="14" y="18" width="12" height="2" rx="1" fill="#a5b4fc" opacity="0.5"/>
      </svg>
      <h1>Kanban</h1>
    </div>
    <p class="app-sub">Simple boards, no clutter.</p>

    <% if (loginError) { %><div class="error-box" style="margin-top:14px;"><%= loginError %></div><% } %>
    <% if (signupError) { %><div class="error-box" style="margin-top:14px;"><%= signupError %></div><% } %>
    <% if (signupSuccess) { %><div class="success-box" style="margin-top:14px;"><%= signupSuccess %></div><% } %>

    <div class="auth-grid">
      <div class="login-card">
        <h2>Sign in</h2>
        <form method="POST" action="/login" class="stack">
          <label>
            <span>Username</span>
            <input type="text" name="username" autocomplete="username" required />
          </label>
          <label>
            <span>Password</span>
            <input type="password" name="password" autocomplete="current-password" required />
          </label>
          <div>
            <button type="submit" class="login-submit">Sign in &rarr;</button>
          </div>
        </form>
      </div>

      <div class="login-card">
        <h2>Create account</h2>
        <form method="POST" action="/signup" class="stack">
          <label>
            <span>Username</span>
            <input type="text" name="username" autocomplete="username" required maxlength="50" />
          </label>
          <label>
            <span>Password <span style="font-weight:400;text-transform:none;letter-spacing:0;">(8+ characters)</span></span>
            <input type="password" name="password" autocomplete="new-password" required minlength="8" />
          </label>
          <div>
            <button type="submit" class="login-submit">Create account &rarr;</button>
          </div>
        </form>
      </div>
    </div>

  </div>
</body>
</html>
