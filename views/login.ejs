<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kanban — Sign in</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-page">
  <div class="auth-shell">

    <div style="text-align: center; margin-bottom: 24px;">
      <div style="display:inline-flex; align-items:center; gap:10px; margin-bottom:8px;">
        <div class="app-logo" style="width:38px;height:38px;border-radius:10px;">
          <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;fill:white;">
            <rect x="1" y="1" width="4" height="10" rx="1"/>
            <rect x="6" y="1" width="4" height="7" rx="1"/>
            <rect x="11" y="1" width="4" height="13" rx="1"/>
          </svg>
        </div>
        <h1 style="font-size:28px; margin:0;">Kanban</h1>
      </div>
      <p class="muted" style="margin:0; font-size:14px;">Simple boards, no clutter.</p>
    </div>

    <div class="login-card">
      <% if (loginError) { %>
        <div class="error-box"><%= loginError %></div>
      <% } %>
      <% if (signupError) { %>
        <div class="error-box"><%= signupError %></div>
      <% } %>
      <% if (signupSuccess) { %>
        <div class="success-box"><%= signupSuccess %></div>
      <% } %>

      <div class="auth-grid">
        <section>
          <h2 style="margin-bottom:14px;">Sign in</h2>
          <form method="POST" action="/login" class="stack">
            <label>
              <span>Username</span>
              <input type="text" name="username" autocomplete="username" required />
            </label>
            <label>
              <span>Password</span>
              <input type="password" name="password" autocomplete="current-password" required />
            </label>
            <button type="submit">Sign in</button>
          </form>
        </section>

        <section style="border-left: 1px solid #e5e7eb; padding-left: 16px;">
          <h2 style="margin-bottom:14px;">Create account</h2>
          <form method="POST" action="/signup" class="stack">
            <label>
              <span>Username</span>
              <input type="text" name="username" autocomplete="username" required maxlength="50" />
            </label>
            <label>
              <span>Password <span class="muted" style="font-weight:400;">(8+ characters)</span></span>
              <input type="password" name="password" autocomplete="new-password" required minlength="8" />
            </label>
            <button type="submit" class="secondary-button" style="border:1px solid #e5e7eb;">Create account</button>
          </form>
        </section>
      </div>
    </div>

  </div>
</body>
</html>
