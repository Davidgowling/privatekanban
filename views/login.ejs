<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Private Kanban</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="login-page">
  <div class="auth-shell">
    <div class="login-card compact-card">
      <h1>Private Kanban</h1>
      <p class="muted">Sign in or create an account.</p>

      <% if (loginError) { %>
        <div class="error-box"><%= loginError %></div>
      <% } %>

      <% if (signupError) { %>
        <div class="error-box"><%= signupError %></div>
      <% } %>

      <% if (signupSuccess) { %>
        <div class="success-box"><%= signupSuccess %></div>
      <% } %>

      <div class="auth-grid">
        <section>
          <h2>Login</h2>
          <form method="POST" action="/login" class="stack">
            <label>
              <span>Username</span>
              <input type="text" name="username" required />
            </label>

            <label>
              <span>Password</span>
              <input type="password" name="password" required />
            </label>

            <button type="submit" class="tiny-button">Login</button>
          </form>
        </section>

        <section>
          <h2>Create account</h2>
          <form method="POST" action="/signup" class="stack">
            <label>
              <span>Username</span>
              <input type="text" name="username" required />
            </label>

            <label>
              <span>Password</span>
              <input type="password" name="password" required />
            </label>

            <button type="submit" class="tiny-button">Create account</button>
          </form>
        </section>
      </div>
    </div>
  </div>
</body>
</html>